{
  "name": "Seiko Watch Theme",
  "settings": [
    {
      "type": "header",
      "content": "General Settings"
    },
    {
      "type": "text",
      "id": "store_name",
      "label": "Store Name",
      "default": "Your Store Name"
    },
    {
      "type": "textarea",
      "id": "store_description",
      "label": "Store Description",
      "default": "Welcome to our Seiko watch store!"
    },
    {
      "type": "header",
      "content": "Hero Banner Settings"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "Discover Timeless Elegance"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Hero Subtitle",
      "default": "Explore our exclusive Seiko collection"
    },
    {
      "type": "header",
      "content": "Footer Settings"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "© 2023 Your Store Name. All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_social_links",
      "label": "Show Social Links",
      "default": true
    }
  ]
}